{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./cache/ts-out"
  },
  "include": [
    "./scripts/**/*.ts",
    "./test/**/*.ts"
  ],
  "exclude": [
    "./src",
    "./server",
    "./node_modules"
  ]
}